# =============================================================================
#  OFFLINE 4D QUANTUM SERVER (Ollama qwen2.5)
#
#  Roma4d narrative: worldtube + spacetime regions align with gate epochs in
#  rt/roma4d_rt.c (quantum_server_demo): H, CNOT, Rz on a 4-qubit statevector.
#  The LLM prompt embeds PAST / PRESENT / FUTURE probability slabs from that
#  simulation — answers must ground in those numbers, not generic QM trivia.
#
#  Prerequisites:
#    - ollama serve   (default :11434)
#    - ollama pull qwen2.5
#    - curl on PATH
#
#  Run (from roma4d/):
#    r4 run demos/quantum_server.r4s
#
#  Optional env (shell):
#    QUANTUM_QUERY="What is P(q0=1)?"   — question for the model
#    QUANTUM_CONTINUE=1                 — load prior amplitudes from TEMP/TMPDIR
#
#  PowerShell example:
#    $env:QUANTUM_QUERY = "Compare PAST vs PRESENT entanglement on q0,q1."
#    .\r4d.ps1 run demos\quantum_server.r4s
# =============================================================================

from libgeo import bump, identity_v4


class Particle:
    """SoA anchor — same pattern as causal_oracle; keeps 4D host story coherent."""
    soa pos: vec4
    soa vel: vec4


def main() -> None:
    N: int = 4096
    _seed: int = bump(11)

    rot_xy: rotor = rotor(angle=0.7853981633974483, plane="xy")
    rot_xw: rotor = rotor(angle=0.05235987755982988, plane="xw")

    # Worldlines: each vec4 tags a sample; w acts as a nominal proper-time coordinate.
    worldtube: list[vec4] = [vec4(x=0, y=0, z=0, w=1) for _ in range(N)]

    _tau: time = t
    slice_now: vec4 = worldtube[0] @ t
    _ = identity_v4(slice_now)

    blade: multivector = multivector()
    _wedge: multivector = worldtube[0] ^ blade

    anchor: Particle = Particle()
    ap: vec4 = anchor.pos
    ap = ap * rot_xw
    anchor.pos = vec4(x=0, y=0, z=0, w=1)

    # Epoch 1–2 (past slab in C): superposition + CNOT entangling spine
    spacetime:
        par for p in worldtube:
            p = p * rot_xy

    spacetime:
        _past_borrow = timetravel_borrow(rot_xy)

    # Epoch 3–4 (present / tail): spread along q2–q3 story + phase-like xw tilt
    spacetime:
        par for p in worldtube:
            p = p * rot_xw

    spacetime:
        pass

    print("")
    print("  ============================================================")
    print("  OFFLINE 4D QUANTUM SERVER  +  Ollama (qwen2.5)")
    print("  ============================================================")
    print("")
    print("  Current simulation time (compile-time slice):")
    print("    t is fixed at compile time; witness = worldtube[0] @ t")
    print("")
    print("  Qubit / entanglement summary:")
    print("    Printed below by quantum_server_demo() from the 4-qubit statevector.")
    print("    Gates: H, CNOT, Rz (see rt/roma4d_rt.c).")
    print("")
    print("  Grounded LLM answer:")
    print("    Follows via curl JSON; model only sees simulated probabilities.")
    print("")
    print("  --- Native quantum server + Ollama output ------------------")

    unsafe:
        scratch: rawptr = mir_alloc(64)
        mir_ptr_store(scratch, _seed)
        _qexit: int = quantum_server_demo()

    print("")
    print("  --- End output ---------------------------------------------")
    print("  Tips: set QUANTUM_QUERY for your question; QUANTUM_CONTINUE=1 to reload")
    print("  amplitudes from the state file path printed above.")
    print("  ============================================================")
    print("")
