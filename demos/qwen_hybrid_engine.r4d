# qwen_hybrid_engine.r4d — mmap largest Ollama blob, zero-copy list[vec4] view, par sweep, chat loop
# Requires: Ollama blobs under ~/.ollama/models/blobs (or USERPROFILE on Windows), curl on PATH for chat.
# Run: r4d demos/qwen_hybrid_engine.r4d

def main() -> int:
    qwen_path: str = mir_get_ollama_qwen_path()

    if qwen_path == "not_found":
        print("qwen_hybrid_engine: no blobs in .ollama/models/blobs — install Ollama and pull a model")
        return 1

    unsafe:
        ptr: rawptr = mir_mmap_gguf(qwen_path)
        weights: list[vec4] = mir_cast_to_vec4_list(ptr, 1000000)
        rot: rotor = rotor(angle=0.0001, plane="xy")
        spacetime:
            par for p in weights:
                p = p * rot

    print("qwen_hybrid_engine: mmap par sweep over 1_000_000 vec4 slots ok")

    _chat: int = mir_qwen_chat_loop()
    _ = _chat

    return 0
