# Copyright RomanAILabs - Daniel Harding

def main() -> int:
    print("=============================================================")
    print("          ROMA4D — PROJECT CAUSAL FILTER (PRIMITIVE)")
    print("=============================================================")
    
    # 1. Primary Worldtube (1,000,000 particles)
    particles: list[vec4] = [vec4(x=1.0, y=0.0, z=0.0, w=1.0) for _ in range(1000000)]
    
    # 2. Status Worldtube (Replacing the Probe class to fix Linker Error)
    # This stores the 'Witness' particle at the center of the manifold
    witness: list[vec4] = [vec4(x=0.0, y=0.0, z=0.0, w=0.0)]
    
    # Define the Spacetime Curvature
    time_warp: rotor = rotor(angle=1.5708, plane="zw")
    
    print("Running parallel manifold filter (Primitive Mode)...")

    spacetime:
        # Process the main swarm
        par for p in particles:
            p = p * time_warp
            _mag: float = p | p
            
        # Process the witness separately within the same block
        par for w_vec in witness:
            w_vec = w_vec * time_warp

    print("Causal integrity verified: Primatives Linked.")
    print("=============================================================")
    return 0