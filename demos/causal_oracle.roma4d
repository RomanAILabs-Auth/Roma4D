# =============================================================================
#  CAUSAL ORACLE + OLLAMA (qwen2.5)
#
#  Spacetime: list[vec4] worldtube, t / @ t, spacetime regions, timetravel_borrow,
#  par sweeps, SoA Particle anchor, unsafe scratch.
#
#  LLM: unsafe block calls builtin ollama_demo() -> rt/roma4d_rt.c runs curl against
#  http://127.0.0.1:11434/api/generate with model qwen2.5 (fixed prompt in C).
#
#  Prerequisites:
#    - ollama serve  (default :11434)
#    - ollama pull qwen2.5
#    - curl on PATH (Windows 10+ ships curl.exe)
#
#  Run:  r4d run demos/causal_oracle.roma4d
#
#  Interactive chat (same Ollama model, multi-turn):  demos/causal_oracle_chat.ps1
# =============================================================================

from libgeo import bump, identity_v4


class Particle:
    """SoA anchor - linker symbol Particle in rt/roma4d_rt.c."""
    soa pos: vec4
    soa vel: vec4


def main() -> None:
    N: int = 25_000
    _seed: int = bump(7)

    rot_xy: rotor = rotor(angle=0.6283185307179586, plane="xy")
    rot_xw: rotor = rotor(angle=0.02094395102393195, plane="xw")

    # Worldline column: one vec4 per state sample (w ~ nominal proper time tag).
    worldtube: list[vec4] = [vec4(x=0, y=0, z=0, w=1) for _ in range(N)]

    _tau: time = t
    slice_now: vec4 = worldtube[0] @ t
    _ = identity_v4(slice_now)

    blade: multivector = multivector()
    _wedge: multivector = worldtube[0] ^ blade

    anchor: Particle = Particle()
    ap: vec4 = anchor.pos
    ap = ap * rot_xw
    anchor.pos = vec4(x=0, y=0, z=0, w=1)

    # Forward evolution (future cone work)
    spacetime:
        par for p in worldtube:
            p = p * rot_xy

    # Past-oriented chronology borrow (MIR chrono read path)
    spacetime:
        _past = timetravel_borrow(rot_xy)

    # Counterfactual steering slab
    spacetime:
        par for p in worldtube:
            p = p * rot_xw

    spacetime:
        pass

    print("")
    print("  ============================================================")
    print("  ROMA4D CAUSAL ORACLE  +  Ollama (qwen2.5)")
    print("  ============================================================")
    print("")
    print("  SPACETIME CONTEXT (fed to model in C curl body):")
    print("    model=qwen2.5  endpoint=http://127.0.0.1:11434/api/generate")
    print("    worldtube: list[vec4]  N=25000")
    print("    regions: par * rot_xy, timetravel_borrow(rot_xy), par * rot_xw")
    print("    witness: worldtube[0] @ t   (compile-time t-slice)")
    print("")
    print("  USER QUESTIONS (embedded in prompt):")
    print("    Q1: What caused a collision at t=42?")
    print("    Q2: What if velocity changed at t=-10?")
    print("")
    print("  --- Ollama JSON response (stdout from curl) ----------------")

    unsafe:
        scratch: rawptr = mir_alloc(64)
        mir_ptr_store(scratch, _seed)
        _ollama_exit: int = ollama_demo()

    print("")
    print("  --- End Ollama output --------------------------------------")
    print("  If empty or errors: run `ollama serve`, then `ollama pull qwen2.5`.")
    print("  Tip: prompt is fixed in rt/roma4d_rt.c (ollama_demo) until host strings land.")
    print("  ============================================================")
    print("")
